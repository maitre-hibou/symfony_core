{% extends 'layouts/default.html.twig' %}

{% block page_title %}Hello World ! | {{ parent() }}{% endblock %}

{% block page_styles %}
    <style>
        .product-device {
            position: absolute;
            right: 10%;
            bottom: -30%;
            width: 300px;
            height: 540px;
            background-color: #333;
            border-radius: 21px;
            transform: rotate(30deg);
        }

        .product-device::before {
            position: absolute;
            top: 10%;
            right: 10px;
            bottom: 10%;
            left: 10px;
            content: "";
            background-color: rgba(255, 255, 255, .1);
            border-radius: 5px;
        }

        .product-device-2 {
            top: -25%;
            right: auto;
            bottom: 0;
            left: 5%;
            background-color: #e5e5e5;
        }
    </style>
{% endblock %}

{% block content %}
    <div class="position-relative overflow-hidden p-3 p-md-5 mx-md-3 text-center bg-light">
        <div class="col-md-5 p-lg-5 mx-auto my-5">
            <svg class="d-block mx-auto mb-4" style="fill: #0dcaf0 !important;" width="72" height="57"><use xlink:href="#symfony"></use></svg>
            <h1 class="display-5 fw-bold">Overpowered Symfony Stack</h1>
            <div class="col-lg-6 mx-auto">
                <p class="lead mb-4">Performance & developer friendly development stack for Symfony applications.</p>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a href="#" class="btn btn-primary btn-lg px-4 gap-3" data-bs-toggle="tooltip" data-bs-placement="top" title="Tooltip on top">Read more</a>
                    <a href="#" class="btn btn-outline-secondary btn-lg px-4"><i class="fas fa-cogs"></i> Admin</a>
                </div>
            </div>
        </div>
        <div class="product-device shadow-sm d-none d-md-block"></div>
        <div class="product-device product-device-2 shadow-sm d-none d-md-block"></div>
    </div>
{% endblock %}
